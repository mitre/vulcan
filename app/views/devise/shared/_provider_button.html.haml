-# Renders a centered provider sign-in/register button with the provider's logo stacked above text.
-# Locals: provider (symbol), action (e.g. "Sign in", "Register"), variant ("light", "outline-primary")
- title = oauth_provider_title(provider)
= link_to omniauth_authorize_path(resource_name, provider), class: "btn btn-block btn-#{variant || 'light'} border mb-2 d-flex flex-column align-items-center justify-content-center py-3", method: :post do
  = image_tag oauth_provider_icon(provider), class: "provider-logo mb-1", style: "height: 32px; width: auto"
  %span #{action || 'Sign in'} with #{title}
